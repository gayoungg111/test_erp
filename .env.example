# Vercel Environment Variables (Production 체크 후 Redeploy)

# 1) Supabase → Settings → API → Project URL
supabase_url=https://your-project.supabase.co

# 2) Supabase → Settings → API → anon → public (Reveal 후 복사)
#    ⚠️ service_role secret 키가 아닙니다. 두 키는 서로 다른 값입니다.
supabase_anon_key=eyJhbGciOi...anon_public_key...

# (선택, 다운로드 저장에는 사용 안 함)
supabase_service_role_key=your_service_role_key

GEMINI_API=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
